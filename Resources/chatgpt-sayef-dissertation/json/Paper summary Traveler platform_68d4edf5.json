    "87d63336-a5c8-4aa0-a6aa-82366c050ec9": {
      "id": "87d63336-a5c8-4aa0-a6aa-82366c050ec9",
      "message": {
        "id": "87d63336-a5c8-4aa0-a6aa-82366c050ec9",
        "author": {
          "role": "assistant",
